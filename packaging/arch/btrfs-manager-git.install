post_install() {
  systemctl daemon-reload >/dev/null 2>&1 || true
  echo "Btrfs Manager helper is available through system D-Bus activation."
}

post_upgrade() {
  systemctl daemon-reload >/dev/null 2>&1 || true
  systemctl try-restart btrfs-manager-helper.service >/dev/null 2>&1 || true
}

post_remove() {
  systemctl daemon-reload >/dev/null 2>&1 || true
}
