# Maintainer: MiguelLopesDel <btrfsmanager.protegee996@simplelogin.com>
pkgname=btrfs-manager-git
pkgver=0.1.0.r48.g1eb6e584882c
pkgrel=1
pkgdesc="Modern desktop manager for Btrfs subvolumes and snapshots"
arch=('x86_64')
url="https://github.com/MiguelLopesDel/Btrfs-Manager"
license=('AGPL-3.0-or-later')
depends=('btrfs-progs' 'dbus' 'gtk4' 'libadwaita' 'polkit' 'systemd' 'xdg-utils')
makedepends=('rust' 'cargo' 'git')
optdepends=('grub-btrfs: GRUB snapshot boot integration'
            'refind-btrfs: rEFInd snapshot boot integration')
provides=('btrfs-manager')
conflicts=('btrfs-manager')
install="${pkgname}.install"
source=("${pkgname}::git+https://github.com/MiguelLopesDel/Btrfs-Manager.git#branch=main")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  printf "0.1.0.r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short=12 HEAD)"
}

prepare() {
  cd "$srcdir/$pkgname"
  cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
  cd "$srcdir/$pkgname"
  cargo build --release --frozen -p btrfs-manager-helper -p btrfs-manager-app --features btrfs-manager-app/gui
}

check() {
  cd "$srcdir/$pkgname"
  cargo test --workspace --no-default-features --frozen
}

package() {
  cd "$srcdir/$pkgname"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm755 target/release/btrfs-manager-app "$pkgdir/usr/bin/btrfs-manager-app"
  install -Dm755 target/release/btrfs-manager-helper "$pkgdir/usr/lib/btrfs-manager/btrfs-manager-helper"
  install -Dm644 packaging/linux/org.btrfsmanager.App.desktop "$pkgdir/usr/share/applications/org.btrfsmanager.App.desktop"
  install -Dm644 packaging/dbus/org.btrfsmanager.Helper.conf "$pkgdir/usr/share/dbus-1/system.d/org.btrfsmanager.Helper.conf"
  install -Dm644 packaging/dbus/org.btrfsmanager.Helper.service "$pkgdir/usr/share/dbus-1/system-services/org.btrfsmanager.Helper.service"
  install -Dm644 packaging/polkit/org.btrfsmanager.helper.policy "$pkgdir/usr/share/polkit-1/actions/org.btrfsmanager.helper.policy"
  install -Dm644 packaging/systemd/btrfs-manager-helper.service "$pkgdir/usr/lib/systemd/system/btrfs-manager-helper.service"
  install -Dm644 packaging/systemd/btrfs-manager-snapshot@.service "$pkgdir/usr/lib/systemd/system/btrfs-manager-snapshot@.service"
  install -Dm644 packaging/systemd/btrfs-manager-snapshot@.timer "$pkgdir/usr/lib/systemd/system/btrfs-manager-snapshot@.timer"
}
