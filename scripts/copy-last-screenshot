#!/usr/bin/env bash
set -euo pipefail

SCREENSHOT_GLOB="${SCREENSHOT_GLOB:-/tmp/caelestia-picker-*.png}"
OUT="${SCREENSHOT_CLIPBOARD_OUT:-/tmp/chat-paste.png}"
POLL_SECONDS="${SCREENSHOT_POLL_SECONDS:-1}"

latest_screenshot() {
  local dir pattern latest
  dir="$(dirname "$SCREENSHOT_GLOB")"
  pattern="$(basename "$SCREENSHOT_GLOB")"

  if [ ! -d "$dir" ]; then
    return 1
  fi

  latest="$(
    find "$dir" -maxdepth 1 -type f -name "$pattern" -printf '%T@ %p\n' \
      | sort -nr \
      | sed -n '1{s/^[^ ]* //;p;}'
  )"
  if [ -z "$latest" ]; then
    return 1
  fi
  printf '%s\n' "$latest"
}

prepare_png() {
  local source="$1"

  if command -v magick >/dev/null 2>&1; then
    magick "$source" PNG32:"$OUT"
  else
    cp "$source" "$OUT"
  fi
}

echo "Watching screenshots: $SCREENSHOT_GLOB"
echo "Clipboard output:     $OUT"
echo "Press Ctrl+C to stop."

last_seen=""
provider_pid=""

stop_provider() {
  if [ -n "$provider_pid" ] && kill -0 "$provider_pid" 2>/dev/null; then
    kill "$provider_pid" 2>/dev/null || true
    wait "$provider_pid" 2>/dev/null || true
  fi
  provider_pid=""
}

start_provider() {
  stop_provider
  xclip -selection clipboard -target image/png -loops 0 -i "$OUT" &
  provider_pid="$!"
}

trap 'stop_provider' EXIT INT TERM

while true; do
  if ! latest="$(latest_screenshot)"; then
    echo "No screenshots found; waiting..."
    sleep "$POLL_SECONDS"
    continue
  fi

  if [ "$latest" != "$last_seen" ]; then
    echo "Preparing: $latest"
    prepare_png "$latest"
    last_seen="$latest"
    start_provider
    echo "Serving image on clipboard. Paste into the chat now."
  fi

  sleep "$POLL_SECONDS"
done
